<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="UpUpUp.StartPage"
    Title="卡牌游戏"
    BackgroundColor="#1a1a1a">

    <VerticalStackLayout
        Padding="20"
        Spacing="30"
        VerticalOptions="Center"
        HorizontalOptions="Center">

        <!-- 标题 -->
        <Label
            Text="⚔️ UpUpUp ⚔️"
            FontSize="48"
            FontAttributes="Bold"
            TextColor="White"
            HorizontalTextAlignment="Center" />

        <Label
            Text="一款卡牌战斗游戏"
            FontSize="18"
            TextColor="#AAAAAA"
            HorizontalTextAlignment="Center" />

        <!-- 游戏描述 -->
        <Border
            Padding="15"
            StrokeThickness="1"
            Stroke="#444444"
            BackgroundColor="#2a2a2a">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10"/>
            </Border.StrokeShape>
            <Label
                Text="使用卡牌与敌人战斗！&#10;出牌对敌人造成伤害，&#10;或者增加自己的防御。&#10;击败敌人赢得胜利！"
                FontSize="14"
                TextColor="#CCCCCC"
                LineBreakMode="WordWrap"
                HorizontalTextAlignment="Center" />
        </Border>

        <BoxView HeightRequest="1" Color="#444444" />

        <!-- 开始按钮 -->
        <Button
            x:Name="StartButton"
            Text="开始游戏"
            FontSize="18"
            FontAttributes="Bold"
            Padding="20,15"
            CornerRadius="10"
            BackgroundColor="#4CAF50"
            TextColor="White"
            Clicked="OnStartGameClicked"
            HorizontalOptions="Fill" />

        <!-- 退出按钮 -->
        <Button
            x:Name="ExitButton"
            Text="退出游戏"
            FontSize="14"
            Padding="20,12"
            CornerRadius="10"
            BackgroundColor="#555555"
            TextColor="White"
            Clicked="OnExitClicked"
            HorizontalOptions="Fill" />

    </VerticalStackLayout>

</ContentPage>
